# Copy to %LOCALAPPDATA%\LogicLens\.env after install, or use /setup in the app.
# For development, copy to project root as `.env`.

GROQ_API_KEY=
GEMINI_API_KEY=

# Optional overrides (defaults work for desktop: data under %LOCALAPPDATA%\LogicLens)
# LOGICLENS_DATA_DIR=C:\path\to\custom\data
# Skip parsing huge JS bundles (default 400000). Lower to exclude more vendor-like files.
# LOGICLENS_MAX_JS_BYTES=400000
# CHROMA_COLLECTION_NAME=codebase_nodes
# FLASK_HOST=127.0.0.1
# FLASK_PORT=5000
# LOGICLENS_DEBUG=1
