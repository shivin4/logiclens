# Copy to %LOCALAPPDATA%\LogicLens\.env after install, or use /setup in the app.
# For development, copy to project root as `.env`.

GROQ_API_KEY=
GEMINI_API_KEY=

# Optional overrides (defaults work for desktop: data under %LOCALAPPDATA%\LogicLens)
# LOGICLENS_DATA_DIR=C:\path\to\custom\data
# Skip parsing huge JS bundles (default 400000). Lower to exclude more vendor-like files.
# LOGICLENS_MAX_JS_BYTES=400000
# Legacy: single global Chroma collection (CLI only). The app uses one collection per project folder.
# CHROMA_COLLECTION_NAME=codebase_nodes
# FLASK_HOST=127.0.0.1
# FLASK_PORT=5000
# LOGICLENS_DEBUG=1
# Force full graph + Chroma rebuild (skip incremental fingerprints)
# LOGICLENS_FULL_ANALYZE=1
# Display / update-check version (defaults to logiclens/version.py when unset)
# LOGICLENS_APP_VERSION=1.1.0
# Optional: override GitHub repo for “Check for updates”
# LOGICLENS_GITHUB_OWNER=shivin4
# LOGICLENS_GITHUB_REPO=logiclens
# Opt-in crash reporting (requires sentry-sdk; no data sent without SENTRY_DSN)
# LOGICLENS_TELEMETRY=1
# SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project
